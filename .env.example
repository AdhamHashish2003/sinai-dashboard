# Database — local Docker or hosted Postgres (Neon, Supabase, Railway)
DATABASE_URL=postgresql://sinai:sinai_dev_password@localhost:5433/sinai_dashboard

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3002

# GitHub OAuth (production auth)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Webhook secret for /api/webhooks/saas
WEBHOOK_SECRET=sinai-dev-webhook-secret

# ─── Future Integration Keys (not required yet) ──────────────────────────────

# Instagram / Meta Graph API
# INSTAGRAM_ACCESS_TOKEN=

# TikTok API
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# Shopify Admin API
# SHOPIFY_STORE_DOMAIN=
# SHOPIFY_ADMIN_API_TOKEN=

# Google Analytics 4 Data API
# GA4_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Search Console API
# GSC_SITE_URL=
