generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth.js required models ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Products (multi-tenant root) ────────────────────────────────────────────

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  tagline          String?
  status           String   @default("idea") // idea, building, launched, active, retired
  icp              String?  // ideal customer profile
  targetKeywords   String[] @default([])
  targetSubreddits String[] @default([])
  valueProp        String?
  freeTierHook     String?
  prodUrl          String?
  anthropicKey     String?
  groqKey          String?
  telegramChatId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  signals          Signal[]
  replies          Reply[]
  leads            Lead[]
  scoutJobs        ScoutJob[]
  proofPosts       ProofPost[]

  @@index([status])
}

// ─── Radar Signals ───────────────────────────────────────────────────────────

model Signal {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  source    String   // reddit, hackernews
  sourceUrl String
  title     String
  body      String   @db.Text
  author    String
  score     Int
  reason    String
  status    String   @default("new") // new, approved, dismissed, ready_to_draft, posted
  createdAt DateTime @default(now())
  reply     Reply?

  @@unique([productId, sourceUrl])
  @@index([productId, score])
  @@index([status])
  @@index([createdAt])
}

// ─── Content Flywheel: Proof Posts ───────────────────────────────────────────

model ProofPost {
  id                String    @id @default(cuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  postType          String    // city_report, fee_comparison, adu_case_study
  topic             String    // city name or comparison label
  generatedBody     String    @db.Text
  generatedAssets   Json      @default("[]") // array of file paths / URLs
  targetPlatforms   Json      @default("[]") // ["reddit","linkedin","twitter","biggerpockets"]
  postedPlatforms   Json      @default("[]") // what you actually posted to
  draftVersions     Json      @default("[]") // [{body, createdAt, note?}]
  status            String    @default("draft") // draft, approved, posted, rejected, failed
  postedEngagement  Int?      // nullable; manual entry for future adaptive rotation
  errorMessage      String?   @db.Text
  scheduledFor      DateTime?
  postedAt          DateTime?
  createdAt         DateTime  @default(now())

  @@index([productId, status])
  @@index([productId, postType, createdAt])
  @@index([status])
  @@index([createdAt])
}

// ─── CRM: Leads + Scout Jobs ─────────────────────────────────────────────────

model Lead {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  source         String    // scout, radar, manual, inbound
  sourceUrl      String?   // nullable — manual leads may have none
  name           String
  email          String?
  company        String?
  role           String?
  city           String?
  state          String?
  enrichmentJson Json      @default("{}")
  status         String    @default("new") // new, enriched, contacted, replied, trial, paid, dead
  lastTouchAt    DateTime?
  replyReceived  Boolean   @default(false)
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())

  @@unique([productId, sourceUrl])
  @@index([productId, status])
  @@index([status])
  @@index([createdAt])
}

model ScoutJob {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  ghostcrewJobId String?
  targetType     String    // cslb_adu_builders, permit_expediters, small_gcs
  state          String
  city           String?
  limitCount     Int       @default(100)
  status         String    @default("queued") // queued, running, done, failed
  resultsCount   Int       @default(0)
  error          String?   @db.Text
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([productId, status])
  @@index([createdAt])
}

// ─── Swarm Replies ───────────────────────────────────────────────────────────

model Reply {
  id            String    @id @default(cuid())
  signalId      String    @unique
  signal        Signal    @relation(fields: [signalId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  draftBody     String    @default("") @db.Text
  draftVersions Json      @default("[]") // [{body, createdAt, note?}]
  status        String    @default("pending_draft") // pending_draft, ready_to_post, posted, rejected
  platform      String    // reddit, hackernews
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  postedAt      DateTime?

  @@index([productId, status])
  @@index([status])
  @@index([createdAt])
}

// ─── SaaS Analytics ──────────────────────────────────────────────────────────

model SaasProduct {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())
  metrics   SaasMetric[]
  webhooks  WebhookEvent[]
}

model SaasMetric {
  id          String      @id @default(cuid())
  productId   String
  product     SaasProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  mrrCents    Int
  activeUsers Int
  churnRate   Float
  recordedAt  DateTime

  @@index([productId, recordedAt])
  @@index([recordedAt])
}

// ─── Social Media ─────────────────────────────────────────────────────────────

model SocialAccount {
  id        String         @id @default(cuid())
  platform  String
  handle    String
  avatarUrl String?
  bio       String?
  createdAt DateTime       @default(now())
  metrics   SocialMetric[]
  posts     ContentPost[]
}

model SocialMetric {
  id              String        @id @default(cuid())
  accountId       String
  account         SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  followers       Int
  followersChange Int
  impressions     Int
  engagementRate  Float
  recordedAt      DateTime

  @@index([accountId, recordedAt])
  @@index([recordedAt])
}

model ContentPost {
  id           String        @id @default(cuid())
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title        String
  platform     String
  status       String
  thumbnailUrl String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())

  @@index([scheduledAt])
  @@index([status])
}

// ─── SEO ──────────────────────────────────────────────────────────────────────

model KeywordRanking {
  id           String   @id @default(cuid())
  keyword      String
  position     Int
  prevPosition Int
  url          String
  recordedAt   DateTime

  @@index([recordedAt])
  @@index([keyword])
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────

model WebhookEvent {
  id         String       @id @default(cuid())
  source     String
  event      String
  payload    Json
  productId  String?
  product    SaasProduct? @relation(fields: [productId], references: [id])
  receivedAt DateTime     @default(now())

  @@index([receivedAt])
  @@index([source])
}

// ─── Analytics: Page Views ────────────────────────────────────────────────────

model PageView {
  id             String   @id @default(cuid())
  date           DateTime
  totalViews     Int
  uniqueVisitors Int

  @@unique([date])
  @@index([date])
}

// ─── Analytics: Traffic Sources ───────────────────────────────────────────────

model TrafficSource {
  id       String   @id @default(cuid())
  date     DateTime
  source   String   // organic, direct, social, referral, paid
  visitors Int

  @@index([date])
  @@index([source])
}

// ─── Analytics: SEO Snapshots ─────────────────────────────────────────────────

model SeoSnapshot {
  id              String   @id @default(cuid())
  date            DateTime
  domainAuthority Int
  indexedPages    Int
  topLandingPage  String
  topLandingViews Int

  @@unique([date])
  @@index([date])
}

// ─── Analytics: Sales & Revenue ───────────────────────────────────────────────

model SalesOrder {
  id             String   @id @default(cuid())
  date           DateTime
  totalOrders    Int
  revenueCents   Int
  aovCents       Int
  conversionRate Float

  @@unique([date])
  @@index([date])
}

// ─── Analytics: Top Products ──────────────────────────────────────────────────

model TopProduct {
  id           String   @id @default(cuid())
  name         String
  revenueCents Int
  unitsSold    Int
  recordedAt   DateTime

  @@index([recordedAt])
  @@index([revenueCents])
}

// ─── Analytics: Conversion Funnel ─────────────────────────────────────────────

model FunnelSnapshot {
  id        String   @id @default(cuid())
  date      DateTime
  visitors  Int
  addToCart Int
  checkout  Int
  purchase  Int

  @@unique([date])
  @@index([date])
}

// ─── Connections (Auto-Linking) ───────────────────────────────────────────────

model Connection {
  id                     String             @id @default(cuid())
  platform               String             // instagram, tiktok, youtube, twitter, linkedin
  username               String
  type                   String             // social, web
  status                 String             @default("active") // active, paused, error
  dataSource             String             @default("manual") // manual, api
  avatarUrl              String?
  bio                    String?
  lastFetchedAt          DateTime?
  refreshIntervalMinutes Int                @default(30)
  createdAt              DateTime           @default(now())
  metrics                ConnectionMetric[]
  webMetrics             WebMetric[]

  @@unique([platform, username])
  @@index([status])
  @@index([type])
}

model ConnectionMetric {
  id             String     @id @default(cuid())
  connectionId   String
  connection     Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  date           DateTime
  followers      Int        @default(0)
  following      Int        @default(0)
  posts          Int        @default(0)
  engagementRate Float      @default(0)
  views          Int        @default(0)
  likes          Int        @default(0)
  comments       Int        @default(0)
  shares         Int        @default(0)

  @@index([connectionId, date])
  @@index([date])
}

model WebMetric {
  id                 String     @id @default(cuid())
  connectionId       String
  connection         Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  date               DateTime
  pageViews          Int        @default(0)
  uniqueVisitors     Int        @default(0)
  bounceRate         Float      @default(0)
  avgSessionDuration Float      @default(0)
  topPages           Json       @default("[]")

  @@index([connectionId, date])
  @@index([date])
}

// ─── Widget Layout ────────────────────────────────────────────────────────────

model WidgetLayout {
  id       String @id @default(cuid())
  widgetId String @unique
  position Int
}
